         default intermediate directories collide (MSB8028); a source file
         compiled by both with different flags could clobber the other
         project's differently-compiled object. $(ProjectName) keeps this
         project's objects in their own folder regardless of what either
         project later compiles. -->
    <IntDir>$(Platform)\$(Configuration)\$(ProjectName)\</IntDir>
  </PropertyGroup>
